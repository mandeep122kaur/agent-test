"files": [ { "path": "HelloWorld.py","content": "from fastapi import FastAPI\n\napp = FastAPI()\n\n@app.get(\"/\")\ndef read_root():\n    return {\"Hello\": \"API World\"}\n"     },{       "path": "pydantic_base.py","content": "from fastapi import FastAPI\nfrom pydantic import BaseModel\n\napp = FastAPI()\n\nclass Employee(BaseModel):\n    id: int\n    name: str\n    position: str | None = None # Optional field\n    salary: float | None = None # Optional field\n\n@app.post(\"/employees/\")\nasync def create_employee(employee: Employee):\n    ##employee ={\"id\":1,'name':\"John Doe\",'position':\"Software Engineer\",'salary':60000}\n    return employee\n\n@app.post(\"/get_employees/{id}\")\nasync def get_employee(id: int,employee: Employee,salary: str | None = None):\n    result = {\"id\": id,**employee.model_dump()}\n    if salary:\n        result.update({\"salary\": salary})\n    return result\n"     }]